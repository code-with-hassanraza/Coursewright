# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/coursewright

# ─── JWT Auth ───────────────────────────────────────────────────────────────
# Secret key for signing JWT tokens
# Generate a strong one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Environment ────────────────────────────────────────────────────────────
# Options: development | production
ENVIRONMENT=development

# ─── Seed Data ──────────────────────────────────────────────────────────────
# Admin user created automatically on first startup
FIRST_ADMIN_EMAIL=admin@coursewright.com
FIRST_ADMIN_PASSWORD=changeme-in-production

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Example: http://localhost:3000,https://coursewright.com
ALLOWED_ORIGINS=http://localhost:3000