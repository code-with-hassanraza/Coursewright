# backend/.env.example
# Coursewright — Backend Environment Variables Template
#
# ─── HOW TO USE ──────────────────────────────────────────────────────────────
#
#   Windows (PowerShell):
#     Copy-Item backend\.env.example backend\.env
#
#   Mac/Linux:
#     cp backend/.env.example backend/.env
#
#   Then open backend/.env and fill in every value marked ← REQUIRED.
#   Never commit backend/.env to git — it is listed in .gitignore.
#
# ─────────────────────────────────────────────────────────────────────────────

# ─── DATABASE ────────────────────────────────────────────────────────────────
#
# Running WITH Docker Compose (standard local dev):
#   Host must be "db" — the Docker service name, not "localhost".
#   "localhost" inside Docker refers to the backend container itself.
DATABASE_URL=postgresql://postgres:postgres@db:5432/coursewright
#
# Running WITHOUT Docker (direct uvicorn on your machine):
#   Uncomment the line below and comment out the one above.
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/coursewright

# ─── JWT ─────────────────────────────────────────────────────────────────────
#
# SECRET_KEY: signs and verifies every JWT token in the system.
#   - Must be a 32-byte (64 character) hex string.
#   - If this value changes, ALL existing tokens are immediately invalidated
#     and every logged-in user will be logged out.
#   - Generate a secure value with:
#       python -c "import secrets; print(secrets.token_hex(32))"
#   - Never use a short string, a word, or a copy-pasted example value.
SECRET_KEY=REPLACE_WITH_OUTPUT_OF_PYTHON_SECRETS_TOKEN_HEX_32    # ← REQUIRED
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── APPLICATION ─────────────────────────────────────────────────────────────
#
# ENVIRONMENT: controls logging format and debug behavior.
#   development → colored human-readable logs
#   production  → structured JSON logs (for CloudWatch)
ENVIRONMENT=development
#
# ALLOWED_ORIGINS: comma-separated list of frontend origins allowed by CORS.
#   No spaces between entries. Vite dev server runs on port 5173 by default.
#   In production this becomes your CloudFront domain:
#     ALLOWED_ORIGINS=https://your-cloudfront-domain.cloudfront.net
ALLOWED_ORIGINS=http://localhost:5173

# ─── SEED ACCOUNT ────────────────────────────────────────────────────────────
#
# Created automatically on first startup when the users table is empty.
# Use this account to log in to admin endpoints via /docs on first run.
# Change FIRST_ADMIN_PASSWORD to something strong before production deployment.
FIRST_ADMIN_EMAIL=admin@coursewright.com
FIRST_ADMIN_PASSWORD=changeme-in-production

# ─── AI API KEYS ─────────────────────────────────────────────────────────────
#
# Used by the AI teammate's services in backend/app/services/
# All three default to empty string — the app starts even without them.
# The AI service layer handles the empty-key case gracefully.
# Leave blank if you haven't obtained a key yet.
#
# Anthropic (Claude) — primary chatbot
ANTHROPIC_API_KEY=sk-ant-your-key-here
#
# OpenAI (GPT) — fallback
OPENAI_API_KEY=sk-your-key-here
#
# Google (Gemini) — fallback
GEMINI_API_KEY=AI-your-key-here